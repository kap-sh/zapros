#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = []
# ///


import os
import re
import sys

SUBS = [
    # Python keywords
    ("async def", "def"),
    ("async with", "with"),
    ("async for", "for"),
    ("await ", ""),
    # Python stdlib
    ("__aiter__", "__iter__"),
    ("__anext__", "__next__"),
    ("__aenter__", "__enter__"),
    ("__aexit__", "__exit__"),
    ("__anext__", "__next__"),
    ("aiter", "iter"),
    ("AsyncIterator", "Iterator"),
    ("asynccontextmanager", "contextmanager"),
    ("AbstractAsyncContextManager", "AbstractContextManager"),
    # Zapros types / names
    ("Async([A-Z][A-Za-z0-9_]*)", r"\1"),
    ("AsyncClient", "Client"),
    ("AsyncBaseHandler", "BaseHandler"),
    ("AsyncStream", "Stream"),
    ("AsyncClosableStream", "ClosableStream"),
    ("ClientBuilder", "SyncClientBuilder"),
    # Zapros methods
    ("aclose", "close"),
    ("ahandle", "handle"),
    ("aread", "read"),
    ("atext", "text"),
    ("async_iter_bytes", "iter_bytes"),
    ("async_iter_raw", "iter_raw"),
    ("async_next", "next"),
    ("handle_async_request", "handle_request"),
    ("wrap_with_async_middleware", "wrap_with_middleware"),
    # Zapros module paths
    ("zapros._async_base", "zapros._sync_base"),
    ("._async_base", "._sync_base"),
    # pyreqwest
    (
        "from pyreqwest.response import Response as PyreqwestResponse",
        "from pyreqwest.response import SyncResponse as PyreqwestResponse",
    ),
    ("Response as PyreqwestResponse", "SyncResponse as PyreqwestResponse"),
    # Test helpers
    ("pytest_asyncio", "pytest"),
    ("async_mock_server", "mock_server"),
    ("async_mock_builder", "mock_builder"),
]
COMPILED_SUBS = [(re.compile(regex), repl) for regex, repl in SUBS]

USED_SUBS = set()


def unasync_line(line):
    for index, (regex, repl) in enumerate(COMPILED_SUBS):
        old_line = line
        line = re.sub(regex, repl, line)
        if index not in USED_SUBS:
            if line != old_line:
                USED_SUBS.add(index)
    return line


def unasync_file(in_path, out_path):
    with open(in_path) as in_file:
        with open(out_path, "w", newline="") as out_file:
            for line in in_file.readlines():
                if "# unasync: strip" in line:
                    continue
                line = unasync_line(line)
                out_file.write(line)


def unasync_file_check(in_path, out_path):
    import tempfile
    import filecmp

    with tempfile.NamedTemporaryFile(mode="w", delete=False, suffix=".py") as tmp_file:
        tmp_path = tmp_file.name

    try:
        unasync_file(in_path, tmp_path)

        if not filecmp.cmp(tmp_path, out_path, shallow=False):
            print(f"unasync mismatch: {out_path!r} is not up to date")
            print(f"Run 'scripts/unasync' or 'scripts/fix' to regenerate sync files")
            sys.exit(1)
    finally:
        import os

        os.unlink(tmp_path)


def unasync_dir(in_dir, out_dir, check_only=False):
    for dirpath, dirnames, filenames in os.walk(in_dir):
        for filename in filenames:
            if not filename.endswith(".py"):
                continue
            rel_dir = os.path.relpath(dirpath, in_dir)
            in_path = os.path.normpath(os.path.join(in_dir, rel_dir, filename))
            out_path = os.path.normpath(os.path.join(out_dir, rel_dir, filename))
            print(in_path, "->", out_path)
            if check_only:
                unasync_file_check(in_path, out_path)
            else:
                unasync_file(in_path, out_path)


def main():

    check_only = "--check" in sys.argv

    FILES = [
        # Source
        ("src/zapros/_handlers/_async_base.py", "src/zapros/_handlers/_sync_base.py"),
        (
            "src/zapros/_handlers/_async_pyreqwest.py",
            "src/zapros/_handlers/_sync_pyreqwest.py",
        ),
        ("src/zapros/_async_client.py", "src/zapros/_sync_client.py"),
        # Tests
        ("tests/handlers/test_async_basic.py", "tests/handlers/test_sync_basic.py"),
    ]

    for in_path, out_path in FILES:
        if check_only:
            unasync_file_check(in_path, out_path)
        else:
            unasync_file(in_path, out_path)
            print(f"Wrote {out_path}")

    if not check_only and len(USED_SUBS) != len(SUBS):
        unused_subs = [SUBS[i] for i in range(len(SUBS)) if i not in USED_SUBS]

        from pprint import pprint

        print("This SUBS was not used")
        pprint(unused_subs)


if __name__ == "__main__":
    main()
